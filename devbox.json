{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.2/.schema/devbox.schema.json",
  "env": {
    "PIP_ROOT_USER_ACTION": "ignore"
  },
  "packages": [
    "qmk@1.2.0",
    "dos2unix@latest",
    "python313Packages.pip-tools@latest"
  ],
  "shell": {
    "init_hook": [
      "echo Welcome to devbox! > /dev/null"
    ],
    "scripts": {
      "setup": [
        "rm -fr ./qmk_firmware",
        "qmk setup -y -H ./qmk_firmware hangshengkeji/qmk_firmware",
        "python -m pip install -r ./qmk_firmware/requirements.txt"
      ],
      "ln-keyboard": [
        "rm -fr $(pwd)/qmk_firmware/keyboards/rk/r75_pro",
        "ln -s $(pwd)/src/keyboards/rk/r75_pro $(pwd)/qmk_firmware/keyboards/rk/r75_pro"
      ]
    }
  }
}
