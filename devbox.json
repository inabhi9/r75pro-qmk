{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.2/.schema/devbox.schema.json",
  "env": {
    
  },
  "packages": [
    "qmk@1.2.0",
    "dos2unix@latest",
    "python313Packages.appdirs@latest"
  ],
  "shell": {
    "init_hook": [
      
    ],
    "scripts": {
      "setup": [
        "rm -fr $(pwd)/qmk_firmware",
        "qmk setup -y -H $(pwd)/qmk_firmware hangshengkeji/qmk_firmware",
        "devbox run ln-keyboard"
      ],
      "ln-keyboard": [
        "rm -fr $(pwd)/qmk_firmware/keyboards/rk/r75_pro",
        "ln -s $(pwd)/src/keyboards/rk/r75_pro $(pwd)/qmk_firmware/keyboards/rk/r75_pro"
      ],
      "qmk-compile": "qmk compile -kb rk/r75_pro -km default"
    }
  }
}
